{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "MsSqlConnection": "Data Source={0}; Initial Catalog={1}; TrustServerCertificate=True; Integrated Security=False; user={2}; password={3}",
  },
  "AdminOptions": {
    "Password": "yourPassword"
  },
  "Telegram": {
    "BotToken": "yourBotToken"
  },
  "JwtOptions": {
    "SecretKey": "YourSecretKey",
    "Issuer": "YourIssuer",
    "Audience": "YourAudience",
    "ExpirationMinutes": 60
  },
  "AllowedHosts": "*"
}
